<view class="page"><view class="title">保单管理</view><view class="subtitle">销售保费、保司结算与返佣统一计价</view><view wx:if="{{loading}}" class="loading">正在加载保单…</view><view wx:for="{{items}}" wx:key="id" class="card section" data-id="{{item.id}}" bindtap="detail"><view class="row between"><text class="list-title">{{item.policy_no}}</text><text class="tag {{item.status==='active'?'tag-success':'tag-gray'}}">{{item.status_label}}</text></view><view class="list-meta">{{item.insurer}} · {{item.plan_name}} · {{item.insured_count}} 人</view><view class="divider"></view><view class="row between"><text class="muted">保司结算 ¥{{item.policy_floor_total}}</text><text class="strong">销售保费 ¥{{item.sale_total}}</text></view></view><view wx:if="{{!loading&&!items.length}}" class="empty"><view class="empty-icon">保</view><view>暂无有效保单</view></view></view>
