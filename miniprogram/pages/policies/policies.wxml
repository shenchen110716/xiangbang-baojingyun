<view class="page"><view class="title">保单管理</view><view class="subtitle">查看当前单位的整体保单、产品与保障期限</view><view wx:if="{{loading}}" class="loading">正在加载保单…</view><view wx:for="{{items}}" wx:key="id" class="card section" data-id="{{item.id}}" bindtap="detail"><view class="row between"><text class="list-title">{{item.policy_no}}</text><text class="tag {{item.status==='active'?'tag-success':'tag-gray'}}">{{item.status_label}}</text></view><view class="list-meta">{{item.insurer}} · {{item.plan_name}}</view><view class="divider"></view><view class="row between"><text class="muted">{{item.start_date||'—'}} 至 {{item.end_date||'—'}}</text><text class="strong">¥{{item.premium}}</text></view></view><view wx:if="{{!loading&&!items.length}}" class="empty"><view class="empty-icon">保</view><view>暂无已出单保单</view></view></view>
