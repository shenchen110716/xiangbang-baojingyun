<view class="page">
  <view class="title">新增操作员</view><view class="subtitle">操作员将使用独立账号登录当前单位</view>
  <view class="card section">
    <label class="field"><view class="field-label required">姓名</view><input class="input" data-key="name" bindinput="input" /></label>
    <label class="field"><view class="field-label required">登录账号</view><input class="input" data-key="username" bindinput="input" /></label>
    <label class="field"><view class="field-label required">初始密码</view><input class="input" password data-key="password" bindinput="input" placeholder="至少 6 位" /></label>
    <label class="field"><view class="field-label">手机号</view><input class="input" type="number" data-key="phone" bindinput="input" /></label>
    <button class="primary" loading="{{saving}}" disabled="{{saving}}" bindtap="save">创建操作员</button>
  </view>
</view>
