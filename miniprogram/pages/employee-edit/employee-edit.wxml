<view class="page safe-bottom">
  <view class="title">{{id?'编辑员工':'新增参保员工'}}</view>
  <view class="subtitle">选择已审核岗位后，职业类别、保险方案和费率将自动带出</view>
  <view wx:if="{{loading}}" class="loading">正在加载…</view>
  <view wx:else class="card section">
    <label class="field"><view class="field-label required">被保险人姓名</view><input class="input" value="{{form.name}}" placeholder="请输入真实姓名" data-key="name" bindinput="input" /></label>
    <label class="field"><view class="field-label required">身份证号</view><input class="input" value="{{form.id_number}}" placeholder="请输入身份证号" data-key="id_number" bindinput="input" /></label>
    <label class="field"><view class="field-label">手机号</view><input class="input" type="number" maxlength="11" value="{{form.phone}}" placeholder="用于保单和理赔通知" data-key="phone" bindinput="input" /></label>
    <label class="field"><view class="field-label required">投保单位</view><picker range="{{enterprises}}" range-key="name" value="{{enterpriseIndex}}" bindchange="enterpriseChange"><view class="picker">{{enterprises[enterpriseIndex].name||'请选择'}}</view></picker></label>
    <label class="field"><view class="field-label required">已审核岗位</view><picker range="{{positions}}" range-key="name" value="{{positionIndex}}" bindchange="positionChange"><view class="picker">{{positions[positionIndex].name||'暂无可用岗位'}}</view></picker></label>
    <view wx:if="{{selectedPosition}}" class="card-plain" style="background:#f4f7ff">
      <view class="row between"><text class="strong">{{selectedPosition.actual_employer_name}}</text><text class="tag tag-success">{{selectedPosition.occupation_class}}</text></view>
      <view class="list-meta">岗位：{{selectedPosition.name}}｜审核状态：已通过</view>
    </view>
    <label class="field">
      <view class="field-label">生效时间</view>
      <picker mode="date" value="{{form.effective_at}}" data-key="effective_at" bindchange="dateChange"><view class="picker">{{form.effective_at||'不填则不修改'}}</view></picker>
      <view class="list-meta">填写后员工将变为「在保」状态</view>
    </label>
    <label class="field">
      <view class="field-label">停保时间</view>
      <picker mode="date" value="{{form.terminated_at}}" data-key="terminated_at" bindchange="dateChange"><view class="picker">{{form.terminated_at||'不填则不修改'}}</view></picker>
      <view class="list-meta">填写后员工将变为「已停保」状态</view>
    </label>
    <button class="primary" style="margin-top:28rpx" loading="{{saving}}" disabled="{{saving}}" bindtap="save">{{id?'保存员工信息':'提交参保审核'}}</button>
  </view>
</view>
