<view class="page"><view class="title">{{id?'编辑':'新增'}}参保员工</view><view class="muted">职业类别和保险方案由审核通过的岗位自动带出</view><view class="card"><input class="input" placeholder="被保险人姓名（必填）" data-key="name" bindinput="input"/><input class="input" placeholder="身份证号（必填）" data-key="id_number" bindinput="input"/><input class="input" placeholder="手机号（通知使用）" data-key="phone" bindinput="input"/><picker range="{{enterprises}}" range-key="name" value="{{enterpriseIndex}}" bindchange="enterpriseChange"><view class="input">投保单位：{{enterprises[enterpriseIndex].name||'请选择'}}</view></picker><picker range="{{positions}}" range-key="name" value="{{positionIndex}}" bindchange="positionChange"><view class="input">审核岗位：{{positions[positionIndex].name||'暂无可用岗位'}}</view></picker><view class="primary" bindtap="save">{{saving?'提交中…':'提交参保审核'}}</view></view></view>
