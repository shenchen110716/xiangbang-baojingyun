/* 页面整体节流：默认 .page/.search/.chips/.card 的留白是给信息量较少的
   页面用的，员工列表要在一屏里塞下尽量多行，这里按本页需求收紧，只影响
   本页（小程序 wxss 按页面自动作用域，不会串到其它页面）。 */
.page{padding-top:14rpx}
.safe-bottom{padding-bottom:calc(16rpx + env(safe-area-inset-bottom))}
.search{margin:16rpx 0}
.chips{margin:12rpx 0 16rpx}
.card{padding:22rpx 24rpx;margin-bottom:16rpx}
.list-meta{margin-top:6rpx}

.header-bar{padding-bottom:16rpx;margin-bottom:0;border-bottom:1px solid #eef0f5;min-height:56rpx}
/* 参保/停保从顶部固定按钮改成悬浮按钮，贯穿整个列表滚动过程都可见——
   和 .fab（新增理赔的悬浮圆按钮）同一套定位基准（tabBar 上方 130rpx +
   安全区），左右各留 30rpx 边距撑满宽度，两个按钮各占一半。 */
.float-actions{position:fixed;left:30rpx;right:30rpx;bottom:calc(130rpx + env(safe-area-inset-bottom));display:flex;gap:16rpx;z-index:15}
.float-btn{flex:1;height:88rpx;border-radius:44rpx;font-size:28rpx;font-weight:600;line-height:1;box-sizing:border-box}
.float-btn-primary{background:#1d4ed8;color:#fff;box-shadow:0 14rpx 28rpx rgba(29,78,216,.32)}
.float-btn-secondary{background:#fff;color:#1d4ed8;border:2rpx solid #dbe4fb;box-shadow:0 10rpx 24rpx rgba(26,39,84,.12)}
.select-box{box-sizing:border-box;width:44rpx;height:44rpx;border-radius:50%;border:4rpx solid #dbe0ea;background:#f7f8fb;margin-right:18rpx;margin-top:4rpx;flex:none;display:flex;align-items:center;justify-content:center;color:#fff;font-size:30rpx;font-weight:900;line-height:1;transition:transform .12s ease,background-color .12s ease,border-color .12s ease}
.select-box.checked{background:#1d4ed8;border-color:#1d4ed8;transform:scale(1.08);box-shadow:0 4rpx 10rpx rgba(29,78,216,.35)}
.select-bar{position:fixed;left:0;right:0;bottom:0;background:#fff;border-radius:20rpx 20rpx 0 0;padding:16rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));box-shadow:0 -8rpx 24rpx rgba(26,39,84,.1);z-index:20}
.select-bar-date{background:#f7f8fb;border-radius:12rpx;padding:12rpx 16rpx}
