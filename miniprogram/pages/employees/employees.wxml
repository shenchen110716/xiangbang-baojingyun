<view class="page safe-bottom">
  <view wx:if="{{positionId}}" class="header-bar row between">
    <text class="link-btn grow" bindtap="clearPositionFilter">{{positionName||'该岗位'}} · 查看全部员工 →</text>
  </view>
  <view class="search"><input class="input" placeholder="姓名、身份证、手机号或岗位" bindinput="search" /></view>
  <scroll-view class="chips" scroll-x enhanced show-scrollbar="{{false}}">
    <view wx:for="{{statusChips}}" wx:key="value" class="chip {{status===item.value?'active':''}}" data-value="{{item.value}}" bindtap="chooseStatus">{{item.label}}({{item.count}})</view>
  </scroll-view>
  <view wx:if="{{loading}}" class="loading">正在加载员工…</view>
  <view wx:for="{{filtered}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="rowTap">
    <view class="row top">
      <view wx:if="{{selectMode}}" class="select-box {{selectedIds.indexOf(item.id)>-1?'checked':''}}">{{selectedIds.indexOf(item.id)>-1?'✔':''}}</view>
      <view class="grow">
        <view class="row between">
          <view class="row grow" style="min-width:0">
            <text class="list-title" style="flex:none">{{item.name}}</text>
            <text style="margin-left:14rpx;font-size:26rpx;font-weight:500;color:#3a4256;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;min-width:0">{{item.id_masked}}</text>
          </view>
          <text class="tag {{item.status_display==='pending'?'tag-warning':item.status_display==='active'?'tag-success':'tag-gray'}}" style="flex:none;margin-left:12rpx">{{item.status_label}}</text>
        </view>
        <view wx:if="{{item.phone}}" class="list-meta" style="color:#3a4256;font-weight:500">{{item.phone}}</view>
        <view class="list-meta" style="color:#4b5468;font-size:26rpx;font-weight:500">{{item.actual_employer_name||'未关联用工单位'}} · {{item.position_name||'未关联岗位'}}</view>
        <view wx:if="{{item.plan_name}}" style="margin-top:10rpx;color:#5b6479;font-size:25rpx;font-weight:500">{{item.insurer}} · {{item.plan_name}}</view>
        <view wx:if="{{item.effective_at_display}}" style="margin-top:10rpx;color:#5b6479;font-size:25rpx;font-weight:500">参保时间：{{item.effective_at_display}}</view>
        <view wx:if="{{item.terminated_at_display}}" style="margin-top:10rpx;color:#dc2626;font-size:25rpx;font-weight:600">停保时间：{{item.terminated_at_display}}</view>
      </view>
    </view>
  </view>
  <view wx:if="{{!loading&&!filtered.length}}" class="empty"><view class="empty-icon">☷</view><view>暂无符合条件的员工</view><view class="small link-btn" bindtap="importFile">可以手工新增或批量导入</view></view>
  <!-- 参保/停保悬浮按钮和批量停保操作栏都是 position:fixed，不占文档流
       空间，不留个占位高度的话会挡住列表最后几条，还可能因为页面内容
       "看起来"刚好撑满一屏而滚不动。两者互斥（进勾选模式后悬浮按钮就
       让位给底部的批量操作栏），占位高度按各自实际高度留。 -->
  <view wx:if="{{!selectMode}}" style="height:300rpx"></view>
  <view wx:if="{{!selectMode}}" class="float-actions">
    <button class="float-btn float-btn-primary" bindtap="add">＋</button>
    <button class="float-btn float-btn-secondary" data-mode="stopped" bindtap="startSelect">－</button>
  </view>
  <view wx:if="{{selectMode}}" style="height:220rpx"></view>
  <view wx:if="{{selectMode}}" class="select-bar">
    <view class="row between select-bar-date" style="margin-bottom:14rpx">
      <view class="row">
        <text class="strong" style="white-space:nowrap">批量停保</text>
        <text class="tag tag-success" style="margin-left:12rpx">已选 {{selectedIds.length}} 人</text>
      </view>
      <view class="row" style="flex:none">
        <text class="small" style="white-space:nowrap;margin-right:12rpx">停保时间</text>
        <picker mode="date" value="{{stopDate}}" start="{{minStopDate}}" bindchange="stopDateChange"><view class="picker">{{stopDate}}</view></picker>
      </view>
    </view>
    <view class="row" style="gap:14rpx">
      <button class="secondary grow" bindtap="cancelSelect">取消</button>
      <button class="primary grow" loading="{{bulkSubmitting}}" disabled="{{bulkSubmitting}}" bindtap="confirmSelect">确定停保</button>
    </view>
  </view>
</view>
