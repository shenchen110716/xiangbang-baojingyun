<view class="page safe-bottom">
  <view class="row between">
    <view><view class="title">参保员工</view><view class="subtitle">共 {{items.length}} 人，按单位和岗位管理</view></view>
    <button class="mini-btn" bindtap="importFile">批量导入</button>
  </view>
  <view class="search"><input class="input" placeholder="姓名、身份证、手机号或岗位" bindinput="search" /></view>
  <scroll-view class="chips" scroll-x enhanced show-scrollbar="{{false}}">
    <view wx:for="{{statuses}}" wx:key="value" class="chip {{status===item.value?'active':''}}" data-value="{{item.value}}" bindtap="chooseStatus">{{item.label}}</view>
  </scroll-view>
  <view wx:if="{{loading}}" class="loading">正在加载员工…</view>
  <view wx:for="{{filtered}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="detail">
    <view class="row top">
      <view class="avatar">{{item.initial}}</view>
      <view class="grow">
        <view class="row between"><text class="list-title">{{item.name}}</text><text class="tag {{item.status==='active'?'tag-success':item.status==='pending'?'tag-warning':'tag-gray'}}">{{item.status_label}}</text></view>
        <view class="list-meta">{{item.id_masked}}<text wx:if="{{item.phone}}"> · {{item.phone}}</text></view>
        <view class="list-meta">{{item.actual_employer_name||'未关联用工单位'}} · {{item.position_name||'未关联岗位'}}</view>
        <view wx:if="{{item.plan_name}}" class="small" style="margin-top:10rpx">{{item.insurer}} · {{item.plan_name}}</view>
      </view>
    </view>
  </view>
  <view wx:if="{{!loading&&!filtered.length}}" class="empty"><view class="empty-icon">☷</view><view>暂无符合条件的员工</view><view class="small">可以手工新增或批量导入</view></view>
  <view class="fab" bindtap="add">+</view>
</view>
