<view class="page"><view class="row"><view class="title">参保员工</view><button class="btn" bindtap="edit">＋ 新增</button></view><input class="input" placeholder="搜索姓名或手机号" bindinput="search"/><view wx:for="{{items}}" wx:key="id" class="card"><view class="row"><view><text>{{item.name}}</text><view class="muted">{{item.phone}} · {{item.occupation}}</view></view><text class="tag">{{item.status}}</text></view><view style="margin-top:20rpx" class="row"><button class="btn" data-id="{{item.id}}" bindtap="edit">编辑</button><button class="btn danger" data-id="{{item.id}}" bindtap="toggle">停保 / 恢复</button></view></view><view wx:if="{{!items.length}}" class="card muted">暂无参保员工</view></view>
