<view class="page safe-bottom">
  <view wx:if="{{loading}}" class="loading">正在加载案件…</view>
  <view wx:elif="{{item}}">
    <view class="hero"><view class="hero-sub">工伤理赔案件</view><view class="hero-title">{{item.claim_no}}</view><view class="hero-sub">{{item.person_name}} · {{item.actual_employer_name}}</view><view style="margin-top:24rpx"><text class="tag {{item.status==='paid'||item.status==='closed'||item.status==='approved'?'tag-success':item.status==='supplement'||item.status==='rejected'||item.calculated_risk==='high'?'tag-danger':'tag-warning'}}">{{item.status_label}}</text></view></view>
    <view wx:if="{{item.sla_overdue}}" class="card notice" style="background:#fff0f2;color:#d94357"><view class="row between"><view class="strong">案件处理已超出内部时限</view></view><view class="small">当前处理环节耗时超过平台设定的处理时限，建议尽快跟进或联系平台客服。</view></view>
    <view class="grid-2 section"><view class="stat"><text class="stat-label">申请金额</text><text class="stat-value">¥{{item.amount}}</text></view><view class="stat"><text class="stat-label">核赔金额</text><text class="stat-value">¥{{item.approved_amount||0}}</text></view></view>
    <view class="card section"><view class="section-title">案件关系</view><view class="divider"></view><view class="row between"><text class="muted">投保单位</text><text>{{item.enterprise_name}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">实际工作单位</text><text>{{item.actual_employer_name||'—'}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">岗位</text><text>{{item.position_name||'—'}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">保单</text><text>{{item.policy_no||'未关联'}}</text></view></view>
    <view class="card"><view class="section-title">事故与医疗信息</view><view class="divider"></view><view class="row between"><text class="muted">事故时间</text><text>{{item.accident_at}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">事故地点</text><text>{{item.accident_place}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">事故类型</text><text>{{item.accident_type}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">就诊医院</text><text>{{item.hospital||'—'}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">初步诊断</text><text>{{item.diagnosis||'—'}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">就诊费用</text><text>¥{{item.medical_cost||0}}</text></view><view class="divider"></view><view style="line-height:1.7">{{item.description}}</view></view>
    <view class="card notice"><view class="row between"><view><view class="strong">30 日工伤认定时限</view><view class="small">截止 {{item.deadline||'未计算'}}</view></view><text class="tag {{item.deadline_overdue?'tag-danger':'tag-warning'}}">{{item.deadline_text}}</text></view></view>
    <view class="card"><view class="row between"><view><view class="section-title">理赔材料</view><view class="small">完整度 {{item.complete_percent}}% · 已上传 {{documents.length}} 份</view></view><text class="tag {{item.missing_count?'tag-warning':'tag-success'}}">{{item.missing_count?'缺 '+item.missing_count+' 项':'已齐全'}}</text></view><view class="divider"></view>
      <view wx:for="{{checklist}}" wx:key="doc_type" class="row between" style="margin-bottom:22rpx"><view class="grow"><view>{{item.uploaded?'✅':item.status==='rejected'?'❌':'⬜'}} {{item.name}}</view><view class="small">{{item.status==='accepted'?'平台已通过':item.status==='rejected'?'已驳回：'+(item.review_note||'请重新上传'):item.uploaded?'待平台审核':'必需材料'}}</view></view><button wx:if="{{canUpload&&!item.uploaded}}" class="mini-btn" loading="{{uploadingType===item.doc_type}}" data-type="{{item.doc_type}}" bindtap="upload">上传</button><text wx:else class="tag {{item.status==='rejected'?'tag-danger':item.uploaded?'tag-success':'tag-gray'}}">{{item.status==='rejected'?'重传':item.uploaded?'已上传':'待处理'}}</text></view>
      <view wx:if="{{documents.length}}" class="divider"></view><view wx:for="{{documents}}" wx:key="id" class="row between" style="margin-bottom:16rpx"><view class="grow"><view class="ellipsis">{{item.name}}</view><view class="small">{{item.status==='accepted'?'已通过':item.status==='rejected'?'已驳回':'待审核'}} {{item.review_note}}</view></view><text class="link-btn" data-url="{{item.url}}" data-name="{{item.name}}" bindtap="preview">预览</text></view>
      <button wx:if="{{canSubmit}}" class="primary" loading="{{submitting}}" bindtap="submit">材料齐全，提交平台初审</button><view wx:if="{{canUpload&&item.missing_count}}" class="small danger">还缺 {{item.missing_count}} 项材料，齐全后才能提交。</view>
    </view>
    <view class="card"><view class="section-title">保司处理与结果</view><view class="divider"></view><view class="row between"><text class="muted">当前处理人</text><text>{{item.current_handler||'待分配'}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">保司报案号</text><text>{{item.insurer_report_no||'待登记'}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">赔付时间</text><text>{{item.paid_at||'未赔付'}}</text></view><view wx:if="{{item.review_note}}" class="card-plain" style="margin-top:20rpx">审核意见：{{item.review_note}}</view><view wx:if="{{item.rejection_reason}}" class="card-plain" style="margin-top:20rpx;background:#fff0f2;color:#d94357">拒赔原因：{{item.rejection_reason}}</view></view>
    <view class="card"><view class="section-title">完整处理时间线</view><view class="divider"></view><view class="timeline"><view wx:for="{{timeline}}" wx:key="id" class="timeline-item"><view class="strong">{{item.status_label}} · {{item.action}}</view><view wx:if="{{item.note}}" class="list-meta">{{item.note}}</view><view class="small">{{item.operator}} · {{item.created_at}}</view></view></view></view>
  </view>
  <view wx:else class="empty">案件不存在或无权查看</view>
</view>
