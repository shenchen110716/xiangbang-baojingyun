<view class="page safe-bottom"><view wx:if="{{loading}}" class="loading">正在加载案件…</view><view wx:elif="{{item}}"><view class="hero"><view class="hero-sub">理赔案件</view><view class="hero-title">{{item.claim_no}}</view><view class="hero-sub">{{item.person_name}} · {{item.actual_employer_name}}</view><view style="margin-top:24rpx"><text class="tag {{item.status==='paid'||item.status==='closed'?'tag-success':item.status==='supplement'?'tag-danger':'tag-warning'}}">{{item.status_label}}</text></view></view><view class="grid-2 section"><view class="stat"><text class="stat-label">申请金额</text><text class="stat-value">¥{{item.amount}}</text></view><view class="stat"><text class="stat-label">核赔金额</text><text class="stat-value">¥{{item.approved_amount||0}}</text></view></view><view class="card section"><view class="section-title">事故信息</view><view class="divider"></view><view class="row between"><text class="muted">事故时间</text><text>{{item.accident_at}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">事故地点</text><text>{{item.accident_place}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">事故类型</text><text>{{item.accident_type}}</text></view><view class="row between" style="margin-top:20rpx"><text class="muted">申请截止</text><text>{{item.deadline||'—'}}</text></view><view class="divider"></view><view style="line-height:1.7">{{item.description}}</view></view><view class="card"><view class="row between"><view><view class="section-title">理赔材料</view><view class="small">已上传 {{documents.length}} 份</view></view><text class="tag {{item.missing_count?'tag-warning':'tag-success'}}">{{item.missing_count?'缺 '+item.missing_count+' 项':'已齐全'}}</text></view><view class="divider"></view><view wx:for="{{checklist}}" wx:key="doc_type" class="row between" style="margin-bottom:22rpx"><view class="grow"><view>{{item.uploaded?'✅':'⬜'}} {{item.name}}</view><view class="small">{{item.required?'必需材料':'可选材料'}}</view></view><button wx:if="{{!item.uploaded}}" class="mini-btn" loading="{{uploadingType===item.doc_type}}" data-type="{{item.doc_type}}" bindtap="upload">上传</button><text wx:else class="tag tag-success">已上传</text></view><view wx:if="{{documents.length}}" class="divider"></view><view wx:for="{{documents}}" wx:key="id" class="row between" style="margin-bottom:16rpx"><text class="ellipsis grow">{{item.name}}</text><text class="link-btn" data-url="{{item.url}}" bindtap="preview">预览</text></view><button wx:if="{{item.status==='reported'||item.status==='collecting'||item.status==='supplement'}}" class="primary" loading="{{submitting}}" bindtap="submit">材料齐全，提交保司审核</button></view><view class="card"><view class="section-title">处理时间线</view><view class="divider"></view><view class="timeline"><view wx:for="{{timeline}}" wx:key="id" class="timeline-item"><view class="strong">{{item.status_label}} · {{item.action}}</view><view class="list-meta">{{item.note}}</view><view class="small">{{item.operator}} · {{item.created_at}}</view></view></view></view></view><view wx:else class="empty">案件不存在或无权查看</view></view>
