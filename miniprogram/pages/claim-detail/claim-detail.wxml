<view class="page"><view class="title">{{item.claim_no}}</view><view class="muted">{{item.person_name}} · {{statusText[item.status]||item.status}}</view><view class="card"><view class="section-title">案件信息</view><view>事故：{{item.accident_at}} · {{item.accident_place}}</view><view class="muted">{{item.description}}</view><view class="row" style="margin-top:18rpx"><text>申请 ¥{{item.amount}}</text><text>核赔 ¥{{item.approved_amount}}</text></view></view><view class="card"><view class="section-title">材料清单</view><view wx:for="{{checklist}}" wx:key="doc_type" class="row" style="margin:18rpx 0"><text>{{item.uploaded?'✅':'⬜'}} {{item.name}}</text><button wx:if="{{!item.uploaded}}" size="mini" data-type="{{item.doc_type}}" bindtap="upload">上传</button></view><view class="primary" bindtap="submit">提交保司审核</view></view><view class="card"><view class="section-title">处理时间线</view><view wx:for="{{timeline}}" wx:key="id" style="margin-bottom:24rpx"><view>{{statusText[item.node]||item.node}} · {{item.action}}</view><view class="muted">{{item.operator}} · {{item.created_at}}</view></view></view></view>
