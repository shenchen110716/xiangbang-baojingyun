<view class="page safe-bottom"><view class="title">岗位管理</view><view class="subtitle">关联实际工作单位并上传视频，等待平台定类</view>
  <scroll-view class="chips" scroll-x enhanced show-scrollbar="{{false}}"><view wx:for="{{statuses}}" wx:key="value" class="chip {{status===item.value?'active':''}}" data-value="{{item.value}}" bindtap="chooseStatus">{{item.label}}</view></scroll-view>
  <view wx:if="{{loading}}" class="loading">正在加载岗位…</view>
  <view wx:for="{{filtered}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="detail"><view class="row between"><text class="list-title">{{item.name}}</text><text class="tag {{item.status==='approved'?'tag-success':item.status==='supplement'||item.status==='rejected'?'tag-danger':'tag-warning'}}">{{item.status_label}}</text></view><view class="list-meta">{{item.actual_employer_name}} · {{item.occupation_class||'待定'}}</view><view class="row between" style="margin-top:18rpx"><text class="small">岗位视频 {{item.video_count}} 个</text><text class="link-btn">查看详情 →</text></view></view>
  <view wx:if="{{!loading&&!filtered.length}}" class="empty"><view class="empty-icon">岗</view><view>暂无岗位</view></view><view class="fab" bindtap="add">+</view>
</view>
