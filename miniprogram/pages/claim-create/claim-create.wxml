<view class="page"><view class="title">新增工伤报案</view><view class="subtitle">尽快登记事故，系统将按事故日期计算 30 日工伤认定提醒</view>
  <view class="card section">
    <label class="field"><view class="field-label required">投保单位</view><picker range="{{enterprises}}" range-key="name" value="{{enterpriseIndex}}" bindchange="enterpriseChange"><view class="picker">{{enterprises[enterpriseIndex].name||'请选择'}}</view></picker></label>
    <label class="field"><view class="field-label required">受伤员工</view>
      <input class="input" value="{{personQuery}}" placeholder="输入姓名搜索" bindinput="personQueryInput" />
      <picker range="{{people}}" range-key="name" value="{{personIndex}}" bindchange="personChange"><view class="picker" style="margin-top:12rpx">{{people[personIndex].name||'暂无匹配员工'}}</view></picker>
    </label>
    <view class="grid-2"><label class="field"><view class="field-label required">事故日期</view><picker mode="date" bindchange="dateChange"><view class="picker">{{form.accident_date||'请选择'}}</view></picker></label><label class="field"><view class="field-label">事故时间</view><picker mode="time" bindchange="timeChange"><view class="picker">{{form.accident_time||'请选择'}}</view></picker></label></view>
    <label class="field"><view class="field-label required">受伤地址</view><input class="input" data-key="accident_place" bindinput="input" placeholder="请填写事故发生地点" /></label>
    <label class="field"><view class="field-label">事故类型</view><picker range="{{accidentTypes}}" value="{{typeIndex}}" bindchange="typeChange"><view class="picker">{{accidentTypes[typeIndex]}}</view></picker></label>
    <label class="field"><view class="field-label">受伤部位</view><input class="input" value="{{form.injury_part}}" data-key="injury_part" bindinput="input" placeholder="如：右手食指、腰部" /></label>
    <label class="field"><view class="field-label">收款人类型</view><picker range="{{payeeTypes}}" value="{{payeeTypeIndex}}" bindchange="payeeTypeChange"><view class="picker">{{payeeTypeIndex>-1?payeeTypes[payeeTypeIndex]:'请选择'}}</view></picker></label>
    <label class="field"><view class="field-label">就诊医院</view><input class="input" data-key="hospital" bindinput="input" /></label><label class="field"><view class="field-label">初步诊断</view><input class="input" data-key="diagnosis" bindinput="input" /></label>
    <view class="grid-2"><label class="field"><view class="field-label">就诊费用</view><input class="input" type="digit" value="{{form.medical_cost}}" data-key="medical_cost" bindinput="input" /></label><label class="field"><view class="field-label">预计申请金额</view><input class="input" type="digit" value="{{form.amount}}" data-key="amount" bindinput="input" /></label></view>
    <view class="grid-2"><label class="field"><view class="field-label">联系人</view><input class="input" data-key="contact_name" bindinput="input" /></label><label class="field"><view class="field-label">联系电话</view><input class="input" type="number" data-key="contact_phone" bindinput="input" /></label></view>
    <label class="field"><view class="field-label required">事故经过</view><textarea class="textarea" data-key="description" bindinput="input" placeholder="请完整描述事故发生时间、环境、原因和处理经过"></textarea></label>
    <button class="primary" loading="{{saving}}" disabled="{{saving||!people.length}}" bindtap="save">提交工伤报案</button>
  </view>
</view>
