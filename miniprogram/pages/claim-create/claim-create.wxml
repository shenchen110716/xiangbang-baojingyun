<view class="page"><view class="title">新增工伤报案</view><view class="muted">请如实填写事故信息，系统将生成材料清单</view><view class="card"><picker range="{{enterprises}}" range-key="name" bindchange="enterpriseChange"><view class="input">投保单位：{{enterprises[enterpriseIndex].name||'请选择'}}</view></picker><picker range="{{people}}" range-key="name" bindchange="personChange"><view class="input">受伤员工：{{people[personIndex].name||'请选择'}}</view></picker><input class="input" type="text" placeholder="事故时间 YYYY-MM-DD HH:mm" data-key="accident_at" bindinput="input"/><input class="input" placeholder="事故地点" data-key="accident_place" bindinput="input"/><input class="input" placeholder="事故类型" value="工作场所事故" data-key="accident_type" bindinput="input"/><input class="input" placeholder="就诊医院" data-key="hospital" bindinput="input"/><input class="input" placeholder="初步诊断" data-key="diagnosis" bindinput="input"/><input class="input" placeholder="联系人" data-key="contact_name" bindinput="input"/><input class="input" placeholder="联系电话" data-key="contact_phone" bindinput="input"/><input class="input" type="digit" placeholder="预计申请金额" data-key="amount" bindinput="input"/><textarea class="input" style="height:180rpx" placeholder="事故发生经过" data-key="description" bindinput="input"></textarea><view class="primary" bindtap="save">{{saving?'提交中…':'提交工伤报案'}}</view></view></view>
