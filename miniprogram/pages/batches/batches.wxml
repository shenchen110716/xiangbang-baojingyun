<view class="page"><view class="row between"><view><view class="title">参停保中心</view><view class="subtitle">按保险产品生成名单、发送与跟踪回执</view></view><button class="mini-btn" bindtap="importFile">导入</button></view><view class="card section"><view class="row between"><text class="strong">业务日期</text><picker mode="date" value="{{date}}" bindchange="dateChange"><view class="tag">{{date}}</view></picker></view></view><view wx:if="{{loading}}" class="loading">正在加载参停保数据…</view><view wx:for="{{items}}" wx:key="plan_id" class="card"><view class="row between"><view><view class="list-title">{{item.product}}</view><view class="list-meta">{{item.insurer}}</view></view><text class="tag tag-success">在保 {{item.insured_count}}</text></view><view class="grid-2" style="margin-top:24rpx"><view class="card-plain" style="background:#f4f7ff"><view class="small">当日新参</view><view class="strong" style="font-size:36rpx;margin-top:8rpx">{{item.new_count}}</view></view><view class="card-plain" style="background:#f7f8fb"><view class="small">当日停保</view><view class="strong" style="font-size:36rpx;margin-top:8rpx">{{item.stop_count}}</view></view></view><view class="toolbar" style="margin-top:22rpx"><button class="secondary" data-plan="{{item.plan_id}}" data-kind="enrollment" loading="{{sendingId===item.plan_id}}" bindtap="send">发送参保</button><button class="danger-btn" data-plan="{{item.plan_id}}" data-kind="termination" bindtap="send">发送停保</button></view><button wx:if="{{item.insurer_email}}" class="ghost" style="margin-top:14rpx" data-plan="{{item.plan_id}}" data-kind="enrollment" bindtap="email">邮件发送保司名单</button></view><view wx:if="{{!loading&&!items.length}}" class="empty">暂无可用产品的参停保数据</view></view>
