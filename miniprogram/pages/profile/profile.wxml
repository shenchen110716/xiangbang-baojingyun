<view class="page safe-bottom">
  <view class="hero">
    <view class="row">
      <view class="avatar" style="background:rgba(255,255,255,.16);color:#fff">{{userInitial}}</view>
      <view class="grow">
        <view class="hero-title">{{user.name||'企业管理员'}}</view>
        <view class="row"><text class="hero-sub">{{enterprise.name||'当前投保单位'}}</text><text wx:if="{{linkedAccounts.length}}" class="tag" style="margin-left:14rpx;background:rgba(255,255,255,.22);color:#fff" bindtap="switchIdentity">身份切换 ⇄</text></view>
      </view>
    </view>
    <view class="row between" style="margin-top:30rpx"><text class="hero-sub">账号 {{user.username||'未登录'}}</text><text class="tag">企业用户</text></view>
  </view>
  <view class="grid-2 section">
    <view class="stat stat-tappable" data-account="premium" bindtap="goRecharge"><text class="stat-label">保费可用余额 <text class="stat-go">去充值 ›</text></text><text class="stat-value">¥{{dashboard.premium_balance_total||0}}</text><text class="stat-sub">充值 ¥{{dashboard.premium_recharged_total||0}} · 销售保费 ¥{{dashboard.premium_consumed_total||0}}</text></view>
    <view class="stat stat-tappable" data-account="usage" bindtap="goRecharge"><text class="stat-label">服务费可用余额 <text class="stat-go">去充值 ›</text></text><text class="stat-value">¥{{dashboard.usage_available||0}}</text><text class="stat-sub">充值 ¥{{dashboard.usage_recharged||0}} · 已用 ¥{{dashboard.usage_consumed||0}}</text></view>
  </view>
  <view wx:if="{{dashboard.balance_alerts.length}}" class="section">
    <view wx:for="{{dashboard.balance_alerts}}" wx:key="_key" class="card notice notice-danger" data-account="{{item.account}}" bindtap="goRecharge">
      <view class="row between"><text class="strong">账户余额预警</text><text class="tag tag-danger">{{item.days_left}} 天</text></view>
      <view class="list-meta">{{item.account==='premium'?'保费账户':'平台使用费账户'}}余额 ¥{{item.balance}}，请及时充值</view>
    </view>
  </view>
  <view class="card section">
    <view class="menu-item" data-url="/pages/employers/employers" bindtap="go"><view class="menu-icon">企</view><text class="grow">工作单位管理</text><text class="chevron">›</text></view>
    <view class="menu-item" data-url="/pages/positions/positions" bindtap="go"><view class="menu-icon">岗</view><text class="grow">投保岗位与视频</text><text class="chevron">›</text></view>
    <view class="menu-item" bindtap="goEmployees"><view class="menu-icon">员</view><text class="grow">参保员工</text><text class="chevron">›</text></view>
  </view>
  <view class="card section">
    <view class="menu-item" data-url="/pages/products/products" bindtap="go"><view class="menu-icon">保</view><text class="grow">已分配参保产品</text><text class="chevron">›</text></view>
    <view class="menu-item" data-url="/pages/policies/policies" bindtap="go"><view class="menu-icon">单</view><text class="grow">保单管理</text><text class="chevron">›</text></view>
  </view>
  <view class="card section">
    <view class="menu-item" data-url="/pages/billing/billing" bindtap="go"><view class="menu-icon">¥</view><text class="grow">资金账户 / 充值</text><text class="chevron">›</text></view>
    <view class="menu-item" data-url="/pages/reports/reports" bindtap="go"><view class="menu-icon">报</view><text class="grow">经营报表</text><text class="chevron">›</text></view>
  </view>
  <view class="card">
    <view class="menu-item" data-url="/pages/messages/messages" bindtap="go"><view class="menu-icon">信</view><text class="grow">消息与待办</text><text wx:if="{{messageCount}}" class="badge">{{messageCount}}</text><text class="chevron">›</text></view>
    <view class="menu-item" data-url="/pages/timeliness/timeliness" bindtap="go"><view class="menu-icon">率</view><text class="grow">参停保及时率</text><text class="chevron">›</text></view>
    <view class="menu-item" data-url="/pages/operators/operators" bindtap="go"><view class="menu-icon">通</view><text class="grow">企业通讯录</text><text class="chevron">›</text></view>
    <view class="menu-item" data-url="/pages/settings/settings" bindtap="go"><view class="menu-icon">设</view><text class="grow">系统设置</text><text class="chevron">›</text></view>
  </view>
  <button class="secondary" bindtap="switchUser">切换登录用户</button>
  <button class="secondary" bindtap="changePassword">修改登录密码</button>
  <button class="danger-btn" bindtap="logout">退出当前账号</button>
  <view class="small" style="text-align:center;margin-top:24rpx">响帮帮无忧保用户端 v3.5</view>
</view>
