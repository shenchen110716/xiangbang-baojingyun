<view class="page"><view class="title">消息与待办</view><view class="subtitle">余额预警、审核、保单和理赔状态统一提醒</view><view wx:if="{{loading}}" class="loading">正在加载消息…</view><view wx:for="{{items}}" wx:key="id" class="card section {{item.type==='warning'?'notice':item.type==='danger'?'notice notice-danger':''}}" data-path="{{item.path}}" bindtap="open"><view class="row between"><text class="list-title">{{item.title}}</text><text class="tag {{item.type==='success'?'tag-success':item.type==='danger'?'tag-danger':'tag-warning'}}">{{item.type==='todo'?'待办':item.type==='success'?'正常':'提醒'}}</text></view><view class="list-meta">{{item.content}}</view><view class="small" style="margin-top:14rpx">点击查看相关业务 →</view></view></view>
