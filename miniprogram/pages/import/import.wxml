<view class="page"><view class="title">批量参保/停保</view><view class="muted">支持 CSV、XLSX 电子表格，服务端统一校验</view><view class="card"><picker range="{{kinds}}" value="{{kindIndex}}" bindchange="kindChange"><view class="input">业务类型：{{kinds[kindIndex]}}</view></picker><picker range="{{enterprises}}" range-key="name" value="{{enterpriseIndex}}" bindchange="enterpriseChange"><view class="input">投保单位：{{enterprises[enterpriseIndex].name||'请选择'}}</view></picker><picker wx:if="{{kindIndex===0}}" range="{{positions}}" range-key="name" value="{{positionIndex}}" bindchange="positionChange"><view class="input">审核岗位：{{positions[positionIndex].name||'暂无可用岗位'}}</view></picker><view class="btn" bindtap="template">下载电子表格模板</view><view class="primary" style="margin-top:18rpx" bindtap="choose">选择 CSV/XLSX 文件</view></view><view class="card"><view class="row"><text>文件校验</text><text class="muted">{{fileName||'尚未选择'}}</text></view><view class="muted" style="margin-top:16rpx">CSV 已预检 {{rows.length}} 行；XLSX 提交后由服务器校验</view><view wx:for="{{errors}}" wx:key="row" class="danger" style="margin-top:12rpx">第 {{item.row}} 行：{{item.message}}</view></view><view class="primary" bindtap="submit">{{loading?'提交中…':'提交批量业务'}}</view></view>
