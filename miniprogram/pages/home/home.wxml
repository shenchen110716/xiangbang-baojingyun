<view class="page safe-bottom">
  <view class="hero">
    <view class="hero-sub">{{today}}</view>
    <view class="hero-title">{{greeting}}，{{user.name||'企业管理员'}} 👋</view>
    <view class="hero-sub">{{enterprise.name||'响帮帮无忧保'}}｜今日业务运行正常</view>
  </view>

  <view class="grid-2 section">
    <view class="stat stat-tappable" data-status="active" bindtap="goEmployeesByStatus"><text class="stat-label">在保人数 <text class="stat-go">查看 ›</text></text><text class="stat-value">{{totalActiveCount}}</text></view>
    <view class="stat stat-tappable" data-status="pending" bindtap="goEmployeesByStatus"><text class="stat-label">待生效人数 <text class="stat-go">查看 ›</text></text><text class="stat-value">{{totalPendingCount}}</text></view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">参保方案</text>
      <view class="row">
        <text class="section-link" style="margin-right:20rpx" bindtap="togglePositionSearch">🔍 搜索</text>
        <text class="section-link" bindtap="addPosition">+新增岗位</text>
      </view>
    </view>
    <view wx:if="{{positionSearchVisible}}" class="search">
      <input class="input" placeholder="按企业、保险、岗位搜索" value="{{positionSearchQuery}}" bindinput="searchPositions" focus="{{positionSearchVisible}}" />
    </view>
    <view wx:for="{{filteredPositionCards}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="goPosition">
      <view class="row between">
        <text class="list-title">{{item.name}}</text>
        <view class="row">
          <text class="tag tag-success" style="margin-right:10rpx">在保 {{item.active_count}}</text>
          <text wx:if="{{item.pending_count}}" class="tag tag-warning">待生效 {{item.pending_count}}</text>
        </view>
      </view>
      <view class="row between" style="margin-top:6rpx">
        <text class="list-meta" style="color:#4b5468;font-size:26rpx;font-weight:500;margin-top:0">{{item.actual_employer_name||'未关联用工单位'}} · {{item.occupation_class}}</text>
        <view class="row">
          <text class="mini-btn" style="margin-right:20rpx;width:56rpx;height:56rpx;padding:0;font-size:40rpx;font-weight:700;line-height:56rpx;text-align:center;display:inline-block" data-id="{{item.id}}" catchtap="addEnroll">+</text>
          <text class="link-btn">名单 →</text>
        </view>
      </view>
      <view class="small" style="margin-top:18rpx;color:#5b6479;font-size:25rpx;font-weight:500">{{item.plan_text}}</view>
    </view>
    <view wx:if="{{!loading&&!positionCards.length}}" class="empty">
      <view class="empty-icon">案</view>
      <view>暂无已审核通过的岗位</view>
      <view class="small">新增岗位并上传视频，等待平台/保司定类后会出现在这里</view>
      <button class="primary" style="margin-top:24rpx" bindtap="addPosition">+新增岗位</button>
    </view>
    <view wx:if="{{!loading&&positionCards.length&&!filteredPositionCards.length}}" class="empty">
      <view class="empty-icon">🔍</view>
      <view>没有匹配"{{positionSearchQuery}}"的方案</view>
    </view>
  </view>
</view>
