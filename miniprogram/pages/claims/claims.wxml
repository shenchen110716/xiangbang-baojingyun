<view class="page"><view class="row"><view><view class="title">工伤理赔</view><view class="muted">报案、材料、审核、赔付全流程</view></view><view class="primary" bindtap="create">新增报案</view></view><view wx:for="{{items}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="detail"><view class="row"><text>{{item.claim_no}}</text><text class="tag">{{statusText[item.status]||item.status}}</text></view><view style="margin-top:16rpx">{{item.person_name}} · {{item.accident_type}}</view><view class="muted">{{item.accident_at}} · {{item.actual_employer_name}}</view><view class="row" style="margin-top:16rpx"><text>申请 ¥{{item.amount}}</text><text class="{{item.missing_count?'danger':'muted'}}">材料 {{item.document_count}} 份 / 缺 {{item.missing_count}} 项</text></view></view><view wx:if="{{!items.length}}" class="card muted">暂无理赔案件</view></view>
