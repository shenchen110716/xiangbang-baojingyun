<view class="page safe-bottom">
  <view class="title">工伤理赔</view><view class="subtitle">报案、材料、补件、审核和赔付进度全流程跟踪</view>
  <scroll-view class="chips" scroll-x enhanced show-scrollbar="{{false}}"><view wx:for="{{statuses}}" wx:key="value" class="chip {{status===item.value?'active':''}}" data-value="{{item.value}}" bindtap="chooseStatus">{{item.label}}</view></scroll-view>
  <view wx:if="{{loading}}" class="loading">正在加载案件…</view>
  <view wx:for="{{filtered}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="detail">
    <view class="row between"><text class="list-title">{{item.claim_no}}</text><text class="tag {{item.status==='paid'||item.status==='closed'||item.status==='approved'?'tag-success':item.status==='supplement'||item.status==='rejected'||item.calculated_risk==='high'?'tag-danger':'tag-warning'}}">{{item.status_label}}</text></view>
    <view class="list-meta">{{item.person_name}} · {{item.accident_type}}</view><view class="list-meta">{{item.accident_at}} · {{item.actual_employer_name}}</view>
    <view class="divider"></view><view class="row between"><text class="muted">申请金额</text><text class="strong">¥{{item.amount}}</text></view>
    <view class="row between" style="margin-top:18rpx"><text class="small">材料完整度 {{item.complete_percent}}%</text><text class="small {{item.missing_count?'danger':''}}">{{item.missing_count?'缺 '+item.missing_count+' 项':'已齐全'}}</text></view><view class="progress" style="margin-top:12rpx"><view class="progress-in" style="width:{{item.complete_percent}}%"></view></view>
    <view class="row between" style="margin-top:18rpx"><text class="small">当前处理：{{item.current_handler}}</text><text class="small {{item.deadline_overdue?'danger':''}}">30日时限 {{item.deadline_text}}</text></view>
  </view>
  <view wx:if="{{!loading&&!filtered.length}}" class="empty"><view class="empty-icon">+</view><view>暂无理赔案件</view></view><view class="fab" bindtap="create">+</view>
</view>
