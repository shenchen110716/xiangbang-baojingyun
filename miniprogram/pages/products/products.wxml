<view class="page"><view class="title">参保产品</view><view wx:for="{{items}}" wx:key="id" class="card"><view class="row"><text>{{item.insurer}}</text><text class="tag">{{item.status}}</text></view><view style="margin-top:14rpx"><text>{{item.name}}</text><view class="muted">¥{{item.price}} / 人 / {{item.billing_mode==='daily'?'天':'月'}} · {{item.effective_mode==='immediate'?'即时生效':'次日生效'}}</view><view class="muted">{{item.occupation_classes}}</view></view></view><view wx:if="{{!items.length}}" class="card muted">暂无平台分配产品</view></view>
