<view class="page"><view class="title">参保产品</view><view class="subtitle">仅展示平台已为当前单位分配的保险方案</view>
  <view wx:if="{{loading}}" class="loading">正在加载产品…</view>
  <view wx:for="{{items}}" wx:key="id" class="card section" data-id="{{item.id}}" bindtap="detail"><view class="row between"><text class="tag">{{item.insurer}}</text><text class="tag {{item.status==='active'?'tag-success':'tag-gray'}}">{{item.status_label}}</text></view><view class="title" style="font-size:34rpx;margin-top:22rpx">{{item.name}}</view><view class="amount" style="font-size:40rpx;margin-top:18rpx">¥{{item.minimum_sale_price}}<text class="small"> 销售最低价 / 人 / {{item.billing_mode==='daily'?'天':'月'}}</text></view><view class="list-meta">保司结算 ¥{{item.policy_floor_price}} · 总返佣 ¥{{item.total_commission_amount}}</view><view class="divider"></view><view class="row between"><text class="muted">职业类别 {{item.occupation_classes}}</text><text class="link-btn">详情 →</text></view></view>
  <view wx:if="{{!loading&&!items.length}}" class="empty"><view class="empty-icon">保</view><view>暂无已分配产品</view><view class="small">请联系平台顾问配置可投保方案</view></view>
</view>
