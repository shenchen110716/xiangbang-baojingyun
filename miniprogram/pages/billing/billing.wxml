<view class="page"><view class="row between"><view><view class="title">资金与发票</view><view class="subtitle">保费和平台使用费分账户核算</view></view><button class="mini-btn" bindtap="invoice">申请发票</button></view><view wx:if="{{loading}}" class="loading">正在加载账户…</view><view wx:for="{{items}}" wx:key="account" class="card section"><view class="row between"><text class="muted">{{item.account}}</text><text class="tag tag-success">{{item.status}}</text></view><view class="amount" style="margin-top:22rpx">¥{{item.balance_text}}</view><view wx:if="{{item.account==='平台使用费账户'}}" class="card-plain" style="margin-top:24rpx;background:#f7f8fc"><view class="row between"><text class="small">单价</text><text>¥{{item.daily_rate}} / 人 / 天</text></view><view class="row between" style="margin-top:16rpx"><text class="small">预计日消耗</text><text>¥{{item.estimated_text}}</text></view><view class="row between" style="margin-top:16rpx"><text class="small">预计月消耗</text><text>¥{{item.monthly_estimate}}</text></view></view><button class="secondary" style="margin-top:24rpx" data-id="{{item.id}}" data-account="{{item.account==='保费账户'?'premium':'usage'}}" bindtap="recharge">立即充值</button></view><view class="section-head"><text class="section-title">发票申请（{{invoices.length}}）</text></view><view wx:for="{{invoices}}" wx:key="id" class="card"><view class="row between"><text class="strong">{{item.title}}</text><text class="tag {{item.status==='issued'?'tag-success':'tag-gray'}}">{{item.status_label}}</text></view><view class="list-meta">{{item.account==='premium'?'保费账户':'使用费账户'}} · ¥{{item.amount_text}}</view></view><view wx:if="{{!invoices.length&&!loading}}" class="empty">暂无发票申请</view><view class="card notice"><view class="strong">账户说明</view><view class="list-meta">演示环境充值会直接入账。正式环境需对接支付机构、回调验签和日终对账。</view></view></view>
