<view class="page"><view class="title">资金与发票</view><view wx:for="{{items}}" wx:key="index" class="card"><view class="row"><text>{{item.enterprise_name}}</text><text class="tag">{{item.account}}</text></view><view class="amount">¥{{item.balance}}</view><view wx:if="{{item.account==='平台使用费账户'}}" class="muted">单价 ¥{{item.daily_rate}} / 人 / 天，预计日扣费 ¥{{item.estimated_daily}}</view><button size="mini" data-id="{{item.id}}" data-account="{{item.account==='保费账户'?'premium':'usage'}}" bindtap="recharge">充值</button></view><view wx:if="{{!items.length}}" class="card muted">暂无资金账户</view></view>
