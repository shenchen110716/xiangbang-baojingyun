<view class="page safe-bottom"><view class="title">{{id?'岗位详情':'新增投保岗位'}}</view><view class="subtitle">按“岗位信息 → 视频材料 → 平台定类 → 产品费率”流程办理</view>
  <view wx:if="{{loading}}" class="loading">正在加载…</view><view wx:else>
    <view class="card section"><label class="field"><view class="field-label required">实际用工单位</view><picker range="{{employers}}" range-key="name" value="{{employerIndex}}" bindchange="employerChange"><view class="picker">{{employers[employerIndex].name||'请先新增用工单位'}}</view></picker></label><label class="field"><view class="field-label required">岗位名称</view><input class="input" value="{{form.name}}" data-key="name" bindinput="input" placeholder="如：仓储分拣员" /></label><label class="field"><view class="field-label">申报职业类别</view><picker range="{{classes}}" value="{{classIndex}}" bindchange="classChange"><view class="picker">{{classes[classIndex]}}</view></picker></label><label class="field"><view class="field-label">拟投保方案</view><picker range="{{plans}}" range-key="name" value="{{planIndex}}" bindchange="planChange"><view class="picker">{{plans[planIndex].name||'待平台分配产品'}}</view></picker></label><button class="primary" loading="{{saving}}" bindtap="save">{{id?'保存岗位信息':'创建岗位并继续'}}</button></view>
    <view class="card"><view class="row between"><view><view class="section-title">岗位视频</view><view class="small">请拍摄真实工作环境，单个不超过100MB</view></view><text class="tag {{item.status==='approved'?'tag-success':'tag-warning'}}">{{item?item.status:'待上传'}}</text></view><view class="divider"></view><view wx:for="{{videos}}" wx:key="id" class="row between" style="margin-bottom:18rpx"><view class="grow"><view class="ellipsis">{{item.name}}</view><view class="small">{{item.status==='approved'?'已审核':item.status==='rejected'?'已驳回':'等待审核'}} {{item.review_note}}</view></view><text class="tag {{item.status==='approved'?'tag-success':item.status==='rejected'?'tag-danger':'tag-warning'}}">{{item.status}}</text></view><button class="secondary" loading="{{uploading}}" disabled="{{!id||uploading}}" bindtap="uploadVideo">拍摄 / 选择岗位视频</button></view>
    <view wx:if="{{item&&item.status!=='approved'}}" class="card notice">岗位当前不可用于新增参保。请上传视频并等待平台完成职业定类与产品审核。</view>
  </view>
</view>
