<view class="login-page">
  <view class="login-logo">响</view>
  <view class="login-title">响帮帮无忧保</view>
  <view class="subtitle">企业员工保障与理赔服务平台</view>
  <view class="login-card">
    <label class="field">
      <view class="field-label">企业账号</view>
      <input class="input" value="{{username}}" data-field="username" bindinput="input" placeholder="请输入企业账号" autocomplete="username" />
    </label>
    <label class="field">
      <view class="field-label">登录密码</view>
      <input class="input" value="{{password}}" password data-field="password" bindinput="input" placeholder="请输入密码" />
    </label>
    <view wx:if="{{isDevEnv}}" class="row between" bindtap="toggleServer">
      <text class="small">服务连接设置</text><text class="link-btn">{{showServer?'收起':'展开'}}</text>
    </view>
    <label wx:if="{{isDevEnv && showServer}}" class="field">
      <input class="input" value="{{apiBase}}" data-field="apiBase" bindinput="input" placeholder="https://your-domain.com/api" />
      <view class="small">开发者工具本地调试可使用 http://127.0.0.1:8001/api（仅开发/体验版可见）</view>
    </label>
    <button class="primary" loading="{{loading}}" disabled="{{loading}}" bindtap="submit">登录用户端</button>
    <view wx:if="{{error}}" class="error">{{error}}</view>
  </view>
</view>
