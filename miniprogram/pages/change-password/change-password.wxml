<view class="page safe-bottom">
  <view class="card section">
    <label class="field">
      <view class="field-label required">当前密码</view>
      <input class="input" value="{{current}}" password data-key="current" bindinput="input" placeholder="请输入当前密码" />
    </label>
    <label class="field">
      <view class="field-label required">新密码</view>
      <input class="input" value="{{next}}" password data-key="next" bindinput="input" placeholder="至少 6 位" />
    </label>
    <label class="field">
      <view class="field-label required">确认新密码</view>
      <input class="input" value="{{confirm}}" password data-key="confirm" bindinput="input" placeholder="再次输入新密码" />
    </label>
    <button class="primary" loading="{{saving}}" disabled="{{saving}}" bindtap="submit">确认修改</button>
    <view wx:if="{{error}}" class="error">{{error}}</view>
  </view>
</view>
