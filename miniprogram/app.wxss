page{background:#f4f6fa;color:#17213a;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Helvetica Neue",sans-serif;font-size:28rpx}
.page{padding:30rpx 28rpx 56rpx;box-sizing:border-box}
.safe-bottom{padding-bottom:calc(40rpx + env(safe-area-inset-bottom))}
.hero{background:linear-gradient(135deg,#243fba 0%,#4e70ee 58%,#7188f5 100%);color:#fff;border-radius:28rpx;padding:36rpx 32rpx;box-shadow:0 18rpx 44rpx rgba(49,87,229,.22);position:relative;overflow:hidden}
.hero:after{content:"";position:absolute;width:240rpx;height:240rpx;border-radius:50%;right:-70rpx;top:-90rpx;background:rgba(255,255,255,.1)}
.hero-title{font-size:42rpx;font-weight:700;line-height:1.3}
.hero-sub{font-size:25rpx;opacity:.82;margin-top:10rpx}
.title{font-size:40rpx;font-weight:700;line-height:1.35}
.subtitle{font-size:26rpx;color:#7d879e;margin-top:8rpx}
.section{margin-top:32rpx}
.section-head{display:flex;align-items:center;justify-content:space-between;margin:0 4rpx 18rpx}
.section-title{font-size:31rpx;font-weight:650}
.section-link{color:#3157e5;font-size:25rpx}
.card{background:#fff;border-radius:22rpx;padding:28rpx;margin-bottom:22rpx;box-shadow:0 8rpx 28rpx rgba(26,39,84,.055)}
.card-plain{background:#fff;border-radius:20rpx;padding:24rpx}
.row{display:flex;align-items:center}
.between{justify-content:space-between}
.top{align-items:flex-start}
.grow{flex:1;min-width:0}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:18rpx}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16rpx}
.stat{background:#fff;padding:24rpx;border-radius:20rpx;box-shadow:0 6rpx 22rpx rgba(26,39,84,.045)}
.stat-label{font-size:24rpx;color:#7d879e}
.stat-value{display:block;font-size:40rpx;font-weight:700;margin-top:10rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.stat-unit{font-size:23rpx;margin-left:3rpx}
.muted{color:#8892a8;font-size:25rpx}
.small{font-size:23rpx;color:#929bb0}
.strong{font-weight:650}
.amount{font-size:46rpx;font-weight:700;letter-spacing:-1rpx}
.divider{height:1px;background:#edf0f5;margin:24rpx 0}
.input,.picker,.textarea{width:100%;box-sizing:border-box;background:#f8f9fc;border:1px solid #e6e9f1;border-radius:14rpx;padding:0 22rpx;margin-top:12rpx;font-size:27rpx;color:#17213a}
.input,.picker{height:86rpx;line-height:86rpx}
.textarea{min-height:180rpx;padding-top:20rpx}
.field{display:block;margin-bottom:22rpx}
.field-label{font-size:25rpx;color:#5f6b82}
.required:after{content:" *";color:#e44d61}
.primary,.secondary,.danger-btn,.ghost{display:flex;align-items:center;justify-content:center;box-sizing:border-box;border:0;border-radius:14rpx;min-height:82rpx;padding:18rpx 26rpx;font-size:28rpx;line-height:1.2;font-weight:600}
.primary{background:#3157e5;color:#fff}
.secondary{background:#edf1ff;color:#3157e5}
.ghost{background:#f5f7fa;color:#536078}
.danger-btn{background:#fff0f2;color:#d94357}
.primary[disabled],.secondary[disabled]{opacity:.55}
.mini-btn{border:0;background:#edf1ff;color:#3157e5;border-radius:10rpx;padding:12rpx 18rpx;font-size:24rpx;line-height:1.2}
.link-btn{color:#3157e5;font-size:25rpx}
.tag{display:inline-flex;align-items:center;border-radius:999rpx;padding:8rpx 16rpx;font-size:22rpx;background:#eef2ff;color:#3157e5}
.tag-success{background:#eaf8f2;color:#13865f}
.tag-warning{background:#fff5df;color:#b77908}
.tag-danger{background:#fff0f2;color:#d94357}
.tag-gray{background:#f0f2f6;color:#747e92}
.avatar{width:76rpx;height:76rpx;border-radius:22rpx;background:linear-gradient(135deg,#e9edff,#dce4ff);color:#3157e5;display:flex;align-items:center;justify-content:center;font-size:31rpx;font-weight:700;margin-right:20rpx;flex:none}
.list-title{font-size:29rpx;font-weight:650;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.list-meta{font-size:24rpx;color:#8791a7;margin-top:8rpx;line-height:1.55}
.empty{padding:80rpx 30rpx;text-align:center;color:#9099ad}
.empty-icon{font-size:66rpx;opacity:.45;margin-bottom:14rpx}
.loading{padding:50rpx;text-align:center;color:#8a94a9}
.search{display:flex;gap:14rpx;margin:24rpx 0}
.search .input{margin:0;flex:1}
.chips{display:flex;gap:14rpx;overflow-x:auto;white-space:nowrap;margin:18rpx 0 24rpx}
.chip{display:inline-flex;padding:14rpx 24rpx;border-radius:999rpx;background:#fff;color:#707b91;font-size:24rpx}
.chip.active{background:#3157e5;color:#fff}
.quick{background:#fff;border-radius:20rpx;padding:24rpx 10rpx;text-align:center}
.quick-icon{width:74rpx;height:74rpx;border-radius:22rpx;margin:0 auto 14rpx;background:#edf1ff;color:#3157e5;display:flex;align-items:center;justify-content:center;font-size:32rpx;font-weight:700}
.quick-text{font-size:24rpx}
.notice{border-left:7rpx solid #efaa26}
.notice-danger{border-left-color:#e34f61}
.timeline{position:relative;padding-left:32rpx}
.timeline:before{content:"";position:absolute;left:8rpx;top:12rpx;bottom:12rpx;width:2rpx;background:#dfe4ee}
.timeline-item{position:relative;padding-bottom:28rpx}
.timeline-item:before{content:"";position:absolute;width:16rpx;height:16rpx;border-radius:50%;background:#3157e5;left:-31rpx;top:8rpx;border:5rpx solid #edf1ff}
.progress{height:12rpx;border-radius:999rpx;background:#e9edf4;overflow:hidden}
.progress-in{height:100%;background:linear-gradient(90deg,#3157e5,#6f89f3)}
.fab{position:fixed;right:30rpx;bottom:calc(130rpx + env(safe-area-inset-bottom));width:104rpx;height:104rpx;border-radius:50%;background:#3157e5;color:#fff;box-shadow:0 14rpx 32rpx rgba(49,87,229,.35);display:flex;align-items:center;justify-content:center;font-size:48rpx;z-index:10}
.login-page{min-height:100vh;padding:110rpx 46rpx 60rpx;box-sizing:border-box;background:linear-gradient(155deg,#eff3ff 0%,#f8f9fc 55%,#eef2ff 100%)}
.login-logo{width:110rpx;height:110rpx;border-radius:30rpx;background:linear-gradient(135deg,#2444bd,#5875ed);color:#fff;display:flex;align-items:center;justify-content:center;font-size:56rpx;font-weight:700;box-shadow:0 16rpx 38rpx rgba(49,87,229,.28)}
.login-title{font-size:48rpx;font-weight:750;margin-top:32rpx}
.login-card{background:#fff;border-radius:28rpx;padding:34rpx;margin-top:54rpx;box-shadow:0 18rpx 50rpx rgba(29,48,112,.09)}
.error{color:#d94357;font-size:24rpx;margin-top:14rpx}
.toolbar{display:flex;gap:14rpx}
.toolbar button{flex:1}
.menu-item{min-height:94rpx;border-bottom:1px solid #edf0f5;display:flex;align-items:center}
.menu-item:last-child{border-bottom:0}
.menu-icon{width:58rpx;height:58rpx;border-radius:16rpx;background:#edf1ff;color:#3157e5;display:flex;align-items:center;justify-content:center;margin-right:20rpx;font-size:25rpx}
.chevron{color:#aab1c0;font-size:32rpx}
.badge{min-width:30rpx;height:30rpx;line-height:30rpx;border-radius:15rpx;text-align:center;background:#e34f61;color:#fff;font-size:19rpx;padding:0 5rpx}
.nowrap{white-space:nowrap}
.ellipsis{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
