page{background:#f6f7fb;color:#20283f;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC",sans-serif}.page{padding:32rpx}.card{background:#fff;border-radius:20rpx;padding:28rpx;margin-bottom:24rpx;box-shadow:0 6rpx 24rpx rgba(26,39,84,.04)}.title{font-size:40rpx;font-weight:700}.muted{color:#8991a5;font-size:25rpx}.primary{background:#5b6ff3;color:#fff;border-radius:12rpx;padding:22rpx;text-align:center}.row{display:flex;align-items:center;justify-content:space-between}.grid{display:grid;grid-template-columns:1fr 1fr;gap:18rpx}.stat{background:#fff;padding:24rpx;border-radius:16rpx}.stat b{display:block;font-size:42rpx;margin-top:12rpx}.input{height:82rpx;border:1px solid #e5e8f0;border-radius:12rpx;padding:0 22rpx;margin:12rpx 0;font-size:27rpx;background:#fff}.btn{padding:18rpx 24rpx;border-radius:10rpx;background:#eef0ff;color:#5367ed;font-size:25rpx}.danger{color:#e26872}.tag{font-size:22rpx;background:#e9f8f2;color:#1d9d76;padding:8rpx 12rpx;border-radius:8rpx}.login-page{min-height:100vh;padding:140rpx 48rpx;background:linear-gradient(160deg,#eef1ff,#f8f9fc)}.login-logo{width:104rpx;height:104rpx;border-radius:28rpx;background:#5b6ff3;color:#fff;display:flex;align-items:center;justify-content:center;font-size:52rpx;font-weight:700}.login-title{font-size:48rpx;font-weight:700;margin:30rpx 0 12rpx}.login-card{background:#fff;border-radius:24rpx;padding:36rpx;margin-top:48rpx}.login-card input{height:88rpx;border-bottom:1px solid #e8ebf2;margin-bottom:20rpx}.login-card button{margin:28rpx 0}.login-error{color:#e26872;margin:12rpx 0}.section-title{font-size:30rpx;font-weight:600;margin-bottom:18rpx}
