page{background:#f6f7f2;color:#17231e;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Helvetica Neue",sans-serif;font-size:28rpx}
.page{padding:28rpx 28rpx calc(48rpx + env(safe-area-inset-bottom));box-sizing:border-box}
.hero{position:relative;overflow:hidden;background:linear-gradient(145deg,#174f3b,#267258 62%,#3f8b70);color:#fff;border-radius:32rpx;padding:38rpx 34rpx;box-shadow:0 18rpx 42rpx rgba(31,94,70,.2)}
.hero:after{content:"";position:absolute;width:280rpx;height:280rpx;border-radius:50%;right:-100rpx;top:-130rpx;background:rgba(255,255,255,.1)}
.eyebrow{font-size:23rpx;letter-spacing:3rpx;opacity:.76}
.hero-title{font-size:44rpx;font-weight:750;margin-top:18rpx;line-height:1.25}
.hero-sub{font-size:25rpx;opacity:.82;margin-top:12rpx}
.test-badge{display:inline-flex;margin-top:24rpx;padding:9rpx 18rpx;border-radius:999rpx;background:rgba(255,255,255,.16);font-size:22rpx}
.section{margin-top:34rpx}
.section-head{display:flex;align-items:center;justify-content:space-between;margin:0 4rpx 18rpx}
.section-title{font-size:32rpx;font-weight:700}
.section-link{font-size:24rpx;color:#267258}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16rpx}
.stat{background:#fff;border-radius:22rpx;padding:24rpx 20rpx;box-shadow:0 8rpx 26rpx rgba(41,58,49,.05)}
.stat-value{font-size:42rpx;font-weight:760;display:block}
.stat-label{font-size:23rpx;color:#838a82;margin-top:10rpx;display:block}
.card{background:#fff;border-radius:24rpx;padding:28rpx;margin-bottom:20rpx;box-shadow:0 8rpx 28rpx rgba(41,58,49,.05)}
.row{display:flex;align-items:center}
.between{justify-content:space-between}
.top{align-items:flex-start}
.grow{flex:1;min-width:0}
.title{font-size:40rpx;font-weight:760;line-height:1.3}
.subtitle{font-size:25rpx;color:#828980;margin-top:8rpx;line-height:1.5}
.task-title{font-size:29rpx;font-weight:650;line-height:1.45}
.task-title.done{text-decoration:line-through;color:#9aa099}
.meta{font-size:23rpx;color:#8d948c;margin-top:10rpx;line-height:1.5}
.check{width:46rpx;height:46rpx;border:3rpx solid #cfd5cd;border-radius:14rpx;margin-right:20rpx;display:flex;align-items:center;justify-content:center;color:#fff;flex:none;font-size:26rpx}
.check.done{background:#267258;border-color:#267258}
.tag{display:inline-flex;padding:8rpx 15rpx;border-radius:999rpx;font-size:21rpx;background:#edf5f1;color:#267258}
.tag-high{background:#fff0ed;color:#c34b35}
.tag-medium{background:#fff6df;color:#9a6c0b}
.tag-low{background:#eef5ff;color:#4471a9}
.progress{height:14rpx;border-radius:999rpx;background:#e6e9e3;overflow:hidden;margin-top:22rpx}
.progress-in{height:100%;background:linear-gradient(90deg,#267258,#65a58c);border-radius:999rpx}
.quick-grid{display:grid;grid-template-columns:1fr 1fr;gap:18rpx}
.quick{background:#fff;border-radius:22rpx;padding:28rpx 20rpx;text-align:left;box-shadow:0 8rpx 26rpx rgba(41,58,49,.05)}
.quick-icon{width:70rpx;height:70rpx;border-radius:20rpx;background:#edf5f1;color:#267258;display:flex;align-items:center;justify-content:center;font-size:31rpx;font-weight:750}
.quick-title{font-size:27rpx;font-weight:650;margin-top:18rpx;display:block}
.quick-sub{font-size:22rpx;color:#929891;margin-top:7rpx;display:block}
.chips{display:flex;gap:14rpx;white-space:nowrap;margin:24rpx 0;overflow-x:auto}
.chip{padding:14rpx 25rpx;border-radius:999rpx;background:#fff;color:#727a71;font-size:24rpx}
.chip.active{background:#205c45;color:#fff}
.field{display:block;margin-bottom:26rpx}
.field-label{font-size:25rpx;color:#59645d;font-weight:600}
.input,.picker,.textarea{width:100%;box-sizing:border-box;background:#fff;border:1px solid #e2e6df;border-radius:17rpx;margin-top:12rpx;font-size:27rpx;color:#17231e}
.input,.picker{height:88rpx;line-height:88rpx;padding:0 23rpx}
.textarea{min-height:190rpx;padding:22rpx}
.primary,.secondary,.danger{display:flex;align-items:center;justify-content:center;box-sizing:border-box;border:0;border-radius:17rpx;min-height:86rpx;padding:18rpx 28rpx;font-size:28rpx;font-weight:650}
.primary{background:#205c45;color:#fff}
.secondary{background:#eaf3ee;color:#205c45}
.danger{background:#fff0ee;color:#c24a39}
.primary[disabled]{opacity:.5}
.empty{text-align:center;padding:100rpx 30rpx;color:#989e97}
.empty-icon{font-size:70rpx;opacity:.45;margin-bottom:18rpx}
.fab{position:fixed;right:30rpx;bottom:calc(130rpx + env(safe-area-inset-bottom));width:108rpx;height:108rpx;border-radius:50%;background:#205c45;color:#fff;display:flex;align-items:center;justify-content:center;font-size:52rpx;box-shadow:0 16rpx 34rpx rgba(32,92,69,.34);z-index:10}
.timeline{position:relative;padding-left:34rpx}
.timeline:before{content:"";position:absolute;left:8rpx;top:14rpx;bottom:20rpx;width:2rpx;background:#dfe4dd}
.timeline-item{position:relative;margin-bottom:24rpx}
.timeline-item:before{content:"";position:absolute;width:16rpx;height:16rpx;border-radius:50%;background:#267258;left:-33rpx;top:10rpx;border:5rpx solid #eaf3ee}
.log-content{font-size:28rpx;line-height:1.7}
.menu-item{min-height:100rpx;border-bottom:1px solid #edf0eb;display:flex;align-items:center}
.menu-item:last-child{border-bottom:0}
.menu-icon{width:62rpx;height:62rpx;border-radius:18rpx;background:#edf5f1;color:#267258;display:flex;align-items:center;justify-content:center;margin-right:20rpx;font-size:25rpx;font-weight:700}
.chevron{font-size:36rpx;color:#b0b5ae}
.avatar{width:96rpx;height:96rpx;border-radius:28rpx;background:#fff;color:#205c45;display:flex;align-items:center;justify-content:center;font-size:40rpx;font-weight:760;margin-right:22rpx}
.muted{color:#8b928a;font-size:24rpx}
.divider{height:1px;background:#edf0eb;margin:24rpx 0}
